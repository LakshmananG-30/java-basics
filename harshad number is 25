import java.util.*;
public class Solution {
public static void main(String[] args) {
    Scanner sc=new Scanner(System.in);
    int n=sc.nextInt();
    int temp=n;
    int sum=0;
    while(n!=0){
        int l=n%10;
        sum=sum+l;
        n=n/10;
    }
    if (temp%sum==0){
        System.out.println("Yes");
    }
    else{
        System.out.println("No");
    }
    }
}
