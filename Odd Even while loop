import java.util.*;
public class Solution{
    public static void main(String[]args){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int sum1=0;
        int sum2=0;
        while (n!=0){
            int l=n%10;
            if(l%2==0){
                sum1=sum1+1;
            }
            else{
                sum2=sum2+1;
            }
            n=n/10;
        }
        System.out.println("Even: "+sum1);
        System.out.print("Odd: "+sum2);
    }
}
