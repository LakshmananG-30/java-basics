import java.util.*;
public class Solution {
public static void main(String[] args) {
    Scanner sc=new Scanner(System.in);
    int n=sc.nextInt();
    int k=sc.nextInt();
    int count=0;
    while(n!=0){
        int l=n%10;
        if(l==k){
            count++;
        }
        n=n/10;
    }
    System.out.print(count);
    }
}
