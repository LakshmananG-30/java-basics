import java.util.*;
public class Solution{
    public static void main(String[]args){
        Scanner sc=new Scanner(System.in);
        int A=sc.nextInt();
        int B=sc.nextInt();
        if(A%B  == 0){
            System.out.println(A+ " is a multiple of " +B);
        }
        else{
            System.out.println(A+ " is not a multiple of " +B);
        }
    }
}
