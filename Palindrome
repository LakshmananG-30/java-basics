import java.util.*;
public class Solution {
    public static void main(String[] args) {
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int sum=n;
        int rev=0;
        while(n!=0){
            int l=n%10;
            rev=rev*10+l;         
            n=n/10;
        }
        if(rev==sum){
            System.out.println("Yes");
        }
        else{
            System.out.println("No");
        }
    }
}
