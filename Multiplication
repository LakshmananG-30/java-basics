import java.util.*;
public class Solution{
    public static void main(String[]args){
        Scanner sc=new Scanner(System.in);
        int n=sc.nextInt();
        int m=sc.nextInt();
        int product=1;
        for(int i=1;i<=m;i++){
            product=n*i;
        System.out.println(i+"*"+n+"="+product);
        } 
    }
}
